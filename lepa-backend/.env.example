# ============================================
# LEPA Backend Configuration
# ============================================
# Copy this file to .env and fill in your values

# --------------------------------------------
# AWS / Amazon Bedrock Configuration
# --------------------------------------------
# Required for AI models (Claude 4 Sonnet, Claude 3.5 Haiku)

# AWS Region where Bedrock is enabled
AWS_REGION=us-east-1

# AWS Profile name from ~/.aws/credentials (recommended for local dev)
AWS_PROFILE=default

# OR use explicit credentials (not recommended, use IAM roles in production)
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key

# --------------------------------------------
# Apollo.io Configuration
# --------------------------------------------
# Required for company enrichment
# Get your API key from: https://app.apollo.io/#/settings/integrations/api_keys

APOLLO_API_KEY=your_apollo_api_key_here

# --------------------------------------------
# IPInfo Configuration
# --------------------------------------------
# Required for visitor IP -> company resolution
# Get your token from: https://ipinfo.io/account/token

IPINFO_TOKEN=your_ipinfo_token_here

# --------------------------------------------
# Apify Configuration
# --------------------------------------------
# Required for LinkedIn company profile scraping
# Get your API token from: https://console.apify.com/account/integrations

APIFY_API_TOKEN=your_apify_api_token_here

# --------------------------------------------
# Exa Configuration (Phase 2 — Business Signals & Leadership)
# --------------------------------------------
# Required for business signal discovery and leadership search
# Get your API key from: https://dashboard.exa.ai/api-keys

EXA_API_KEY=your_exa_api_key_here

# --------------------------------------------
# BuiltWith Configuration (Phase 2 — Tech Stack Detection)
# --------------------------------------------
# Required for domain-level technology stack detection
# Get your API key from: https://api.builtwith.com/

BUILTWITH_API_KEY=your_builtwith_api_key_here

# --------------------------------------------
# HubSpot Configuration (Phase 3 — CRM Export)
# --------------------------------------------
# Required for pushing account intelligence to HubSpot CRM
# Create a Private App at: https://app.hubspot.com/private-apps
# Grant scopes: crm.objects.companies.read, crm.objects.companies.write

HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token_here

# --------------------------------------------
# Application Settings
# --------------------------------------------

# Enable debug mode (shows detailed errors)
# DEBUG=true

# Log level (DEBUG, INFO, WARNING, ERROR)
# LOG_LEVEL=INFO
